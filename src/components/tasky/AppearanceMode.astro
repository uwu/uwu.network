<video
	id="tasky-light-leaves-overlay"
	src="/tasky/light/leaves.mp4"
	loop
	muted
	playsinline
	preload="none"
	aria-hidden="true"
	transition:name="tasky-light-leaves-overlay"
	transition:persist
></video>
<audio
	id="tasky-light-forest-audio"
	src="/tasky/light/forest.mp3"
	loop
	preload="none"
	aria-hidden="true"
	transition:name="tasky-light-forest-audio"
	transition:persist
></audio>
<video
	id="tasky-moon-overlay"
	src="/tasky/moon/moon.mp4"
	loop
	muted
	playsinline
	preload="none"
	aria-hidden="true"
	transition:name="tasky-moon-overlay"
	transition:persist
></video>
<audio
	id="tasky-moon-audio"
	src="/tasky/moon/night.mp3"
	loop
	preload="none"
	aria-hidden="true"
	transition:name="tasky-moon-audio"
	transition:persist
></audio>

<script is:inline>
(() => {
	const LIGHT_CLASS = "light";
	const MOON_CLASS = "tasky-moon";
	const TRANSITION_CLASS = "tasky-appearance-transition";
	const MODE_KEY = "apperance-mode";
	const APPEARANCE_KEY = "data-appearance";
	const FADE_MS = 420;

	const root = document.documentElement;
	const audioFadeRafs = new Map();
	let transitionTimer = null;
	let waitingForUnlock = false;

	const reducedMotion = () => window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	const getLeaves = () => document.getElementById("tasky-light-leaves-overlay");
	const getForest = () => document.getElementById("tasky-light-forest-audio");
	const getMoon = () => document.getElementById("tasky-moon-overlay");
	const getNight = () => document.getElementById("tasky-moon-audio");

	const persistMode = (mode) => {
		localStorage.setItem(APPEARANCE_KEY, mode === "light" ? "light" : "dark");
		localStorage.setItem(MODE_KEY, mode);
	};

	const stopAudioFade = (audio = null) => {
		if (audio) {
			const key = audio.id || "__anonymous__";
			const raf = audioFadeRafs.get(key);
			if (raf) cancelAnimationFrame(raf);
			audioFadeRafs.delete(key);
			return;
		}
		for (const raf of audioFadeRafs.values()) {
			cancelAnimationFrame(raf);
		}
		audioFadeRafs.clear();
	};

	const fadeAudioVolume = (audio, to, pauseWhenDone = false) => {
		if (!audio) return;
		const key = audio.id || "__anonymous__";
		stopAudioFade(audio);
		if (reducedMotion()) {
			audio.volume = to;
			if (pauseWhenDone && to === 0) {
				audio.pause();
				audio.currentTime = 0;
			}
			return;
		}

		const from = audio.volume;
		if (Math.abs(from - to) < 0.01) {
			audio.volume = to;
			if (pauseWhenDone && to === 0) {
				audio.pause();
				audio.currentTime = 0;
			}
			return;
		}

		const startedAt = performance.now();
		const targetAudio = audio;
		const step = (now) => {
			const progress = Math.min((now - startedAt) / FADE_MS, 1);
			targetAudio.volume = from + ((to - from) * progress);
			if (progress < 1) {
				const raf = requestAnimationFrame(step);
				audioFadeRafs.set(key, raf);
				return;
			}
			audioFadeRafs.delete(key);
			targetAudio.volume = to;
			if (pauseWhenDone && to === 0) {
				targetAudio.pause();
				targetAudio.currentTime = 0;
			}
		};

		const raf = requestAnimationFrame(step);
		audioFadeRafs.set(key, raf);
	};

	const clearUnlockListeners = () => {
		document.removeEventListener("pointerdown", unlockModeAudio);
		document.removeEventListener("keydown", unlockModeAudio);
		document.removeEventListener("touchstart", unlockModeAudio);
		waitingForUnlock = false;
	};

	const unlockModeAudio = () => {
		clearUnlockListeners();
		if (root.classList.contains(MOON_CLASS)) {
			const night = getNight();
			if (!night) return;
			night.volume = 0;
			night.muted = false;
			night.play()
				.then(() => fadeAudioVolume(night, 1))
				.catch(() => {});
			return;
		}
		if (!root.classList.contains(LIGHT_CLASS)) return;
		const forest = getForest();
		if (!forest) return;
		forest.volume = 0;
		forest.muted = false;
		forest.play()
			.then(() => fadeAudioVolume(forest, 1))
			.catch(() => {});
	};

	const queueAudioUnlock = () => {
		if (waitingForUnlock) return;
		waitingForUnlock = true;
		document.addEventListener("pointerdown", unlockModeAudio, { once: true, passive: true });
		document.addEventListener("touchstart", unlockModeAudio, { once: true, passive: true });
		document.addEventListener("keydown", unlockModeAudio, { once: true });
	};

	const withCrossFade = (fn) => {
		if (reducedMotion()) {
			fn();
			return;
		}
		root.classList.add(TRANSITION_CLASS);
		void document.body.offsetWidth;
		fn();
		window.clearTimeout(transitionTimer);
		transitionTimer = window.setTimeout(() => {
			root.classList.remove(TRANSITION_CLASS);
		}, FADE_MS + 80);
	};

	const startLightMedia = () => {
		const leaves = getLeaves();
		if (leaves && leaves.paused) {
			leaves.play().catch(() => {});
		}

		const forest = getForest();
		if (!forest) return;
		clearUnlockListeners();

		if (!forest.paused) {
			forest.muted = false;
			if (forest.volume < 0.99) fadeAudioVolume(forest, 1);
			return;
		}

		forest.volume = 0;
		forest.muted = true;
		forest.play()
			.then(() => {
				forest.muted = false;
				fadeAudioVolume(forest, 1);
			})
			.catch(() => {
				queueAudioUnlock();
			});
	};

	const stopLightMedia = () => {
		clearUnlockListeners();
		fadeAudioVolume(getForest(), 0, true);

		const leaves = getLeaves();
		if (!leaves) return;
		if (reducedMotion()) {
			leaves.pause();
			leaves.currentTime = 0;
			return;
		}
		window.setTimeout(() => {
			const nextLeaves = getLeaves();
			if (!nextLeaves) return;
			nextLeaves.pause();
			nextLeaves.currentTime = 0;
		}, FADE_MS);
	};

	const startMoonMedia = () => {
		const moon = getMoon();
		if (moon && moon.paused) {
			moon.play().catch(() => {});
		}

		const night = getNight();
		if (!night) return;
		clearUnlockListeners();

		if (!night.paused) {
			night.muted = false;
			if (night.volume < 0.99) fadeAudioVolume(night, 1);
			return;
		}

		night.volume = 0;
		night.muted = true;
		night.play()
			.then(() => {
				night.muted = false;
				fadeAudioVolume(night, 1);
			})
			.catch(() => {
				queueAudioUnlock();
			});
	};

	const stopMoonMedia = () => {
		clearUnlockListeners();
		fadeAudioVolume(getNight(), 0, true);

		const moon = getMoon();
		if (!moon) return;
		if (reducedMotion()) {
			moon.pause();
			moon.currentTime = 0;
			return;
		}
		window.setTimeout(() => {
			const nextMoon = getMoon();
			if (!nextMoon) return;
			nextMoon.pause();
			nextMoon.currentTime = 0;
		}, FADE_MS);
	};

	const currentMode = () => {
		if (root.classList.contains(MOON_CLASS)) return "moon";
		if (root.classList.contains(LIGHT_CLASS)) return "light";
		return "dark";
	};

	const readStoredMode = () => {
		const stored = localStorage.getItem(MODE_KEY);
		if (stored === "light" || stored === "dark" || stored === "moon") return stored;
		return currentMode();
	};

	const applyMode = (mode, { animate = true, persist = true } = {}) => {
		const isLight = mode === "light";
		const isMoon = mode === "moon";
		const run = () => {
			if (isLight) {
				root.classList.remove("dark", MOON_CLASS);
				root.classList.add("light");
				root.style.colorScheme = "light";
				stopMoonMedia();
				startLightMedia();
				return;
			}

			root.classList.remove("light");
			root.classList.add("dark");

			if (isMoon) {
				root.classList.add(MOON_CLASS);
				root.style.colorScheme = "dark";
				stopLightMedia();
				startMoonMedia();
				return;
			}

			root.classList.remove(MOON_CLASS);
			root.style.colorScheme = "dark";
			stopLightMedia();
			stopMoonMedia();
		};

		if (animate) withCrossFade(run);
		else run();
		if (persist) persistMode(isLight ? "light" : (isMoon ? "moon" : "dark"));
	};

	const setupAppearanceMode = () => {
		window.__taskyAppearanceCleanup?.();

		const initialMode = readStoredMode();
		applyMode(initialMode, { animate: false, persist: true });

		const toggleLightMode = () => {
			applyMode(currentMode() === "light" ? "dark" : "light");
		};

		const toggleMoonMode = () => {
			applyMode(currentMode() === "moon" ? "dark" : "moon");
		};

		const onKeyDown = (event) => {
			if (event.defaultPrevented || event.ctrlKey || event.metaKey || event.altKey) return;
			const target = event.target;
			if (
				target instanceof HTMLInputElement
				|| target instanceof HTMLTextAreaElement
				|| target instanceof HTMLSelectElement
				|| (target instanceof HTMLElement && target.isContentEditable)
			) {
				return;
			}
			if (event.key === "s" || event.key === "S") {
				event.preventDefault();
				toggleLightMode();
				return;
			}
			if (event.key === "m" || event.key === "M") {
				event.preventDefault();
				toggleMoonMode();
			}
		};

		document.addEventListener("keydown", onKeyDown);

		const cleanup = () => {
			document.removeEventListener("keydown", onKeyDown);
			clearUnlockListeners();
			stopAudioFade();
			window.clearTimeout(transitionTimer);
			root.classList.remove(TRANSITION_CLASS);
			window.__taskyAppearanceCleanup = null;
		};

		window.__taskyAppearanceCleanup = cleanup;
		document.addEventListener("astro:before-swap", cleanup, { once: true });
	};

	document.addEventListener("astro:page-load", setupAppearanceMode);
	setupAppearanceMode();
})();
</script>

<style>
#tasky-light-leaves-overlay {
	position: fixed;
	inset: 0;
	width: 100%;
	height: 100%;
	object-fit: cover;
	object-position: top;
	mix-blend-mode: multiply;
	pointer-events: none;
	opacity: 0;
	z-index: 999;
	transition: opacity 700ms cubic-bezier(0.23, 1, 0.32, 1);
}

:global(html.light) #tasky-light-leaves-overlay {
	opacity: 1;
}

#tasky-moon-overlay {
	position: fixed;
	inset: 0;
	width: 100%;
	height: 100%;
	object-fit: cover;
	pointer-events: none;
	opacity: 0;
	z-index: 999;
	transition: opacity 700ms cubic-bezier(0.23, 1, 0.32, 1);
}

:global(html.tasky-moon) #tasky-moon-overlay {
	opacity: 0.6;
}

@media (max-width: 768px) {
	#tasky-moon-overlay {
		object-position: left;
	}
}

:global(html.tasky-appearance-transition),
:global(html.tasky-appearance-transition *),
:global(html.tasky-appearance-transition *::before),
:global(html.tasky-appearance-transition *::after) {
	transition-property: color, background-color, border-color, text-decoration-color, fill, stroke, box-shadow;
	transition-duration: 420ms;
	transition-timing-function: cubic-bezier(0.23, 1, 0.32, 1);
}

@media (prefers-reduced-motion: reduce) {
	#tasky-light-leaves-overlay,
	#tasky-moon-overlay {
		transition-duration: 0ms;
	}

	:global(html.tasky-appearance-transition),
	:global(html.tasky-appearance-transition *),
	:global(html.tasky-appearance-transition *::before),
	:global(html.tasky-appearance-transition *::after) {
		transition-duration: 0ms;
	}
}
</style>
